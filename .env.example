# Pre-Planner configuration. Copy this file to `.env` and edit. Real environment
# variables take precedence over it. Do NOT commit your filled-in `.env`
# (it is gitignored). Everything here is optional for a local SQLite dev run.

# REQUIRED in production — signs sessions, flash messages, and CSRF tokens.
# Generate one with:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# Database. Omit entirely for a zero-config SQLite file under instance/.
#   MySQL / MariaDB (e.g. PythonAnywhere — note the literal $ in the db name):
# DATABASE_URL=mysql+pymysql://user:password@host/user$preplanner?charset=utf8mb4
#   PostgreSQL:
# DATABASE_URL=postgresql+psycopg://user:password@localhost/preplanner

# Where uploaded files (floor plans, library assets) are stored. Defaults to
# instance/uploads. In production use an absolute path on a persistent disk.
# UPLOAD_FOLDER=/var/lib/preplanner/uploads

# Rate-limit store. Default is in-memory (fine for a single process). For multiple
# workers, share login limits via Redis:
# RATELIMIT_STORAGE_URI=redis://localhost:6379
