# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.venv/
venv/
env/

# Secrets & generated deploy files (never commit these)
.env
.env.bak
deploy/wsgi_generated.py

# Flask instance folder (holds the local SQLite DB, secrets, uploads)
instance/

# Uploaded floor-plan images (kept out of version control)
app/static/uploads/

# Local GIS source data (large rasters/shapefiles, not for the repo)
GIS Data/

# Brand-source assets (logos, splash, favicons). The two files the app actually
# serves live in app/static/images/ and ARE tracked; this master set is kept out so
# anyone self-hosting this AGPL app supplies their own branding. Root-anchored so it
# does NOT match app/static/images/ or vendored image folders.
/images/

# OS / editor
.DS_Store
*.swp
.idea/
.vscode/

# Local Claude Code settings (personal, not for the repo)
.claude/settings.local.json
